# Copy this file to .env for local development (never commit .env to git)

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key

# ── Database ──────────────────────────────────────────────────────────────────
# Render provides DATABASE_URL automatically when you add a PostgreSQL service.
# Leave as SQLite for local development.
DATABASE_URL=sqlite:///./ielts_mock.db

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for AI essay feedback and Telegram coaching.
# Leave empty to fall back to rule-based responses.
OPENAI_API_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get a token from @BotFather on Telegram.
# Leave empty to disable the bot.
TELEGRAM_BOT_TOKEN=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used by the bot to generate deep-links back to the frontend.
FRONTEND_URL=https://your-frontend.vercel.app
